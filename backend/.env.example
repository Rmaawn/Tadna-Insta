# ====== Tadna Insta — Backend environment ======
# Copy this file to ".env" and fill in your values.

# --- App ---
APP_NAME="Tadna Insta"
ENVIRONMENT=development
# Comma-separated list of allowed CORS origins (frontend URL)
CORS_ORIGINS=http://localhost:3000

# --- Database ---
# Default is local SQLite. To move to Postgres later:
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/tadna
DATABASE_URL=sqlite+aiosqlite:///./tadna.db

# --- OpenAI (REQUIRED for AI recommendations) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Instagram (OPTIONAL but strongly recommended) ---
# Logging in once with a real account makes fetching far more reliable.
# A session is cached to disk after first login, so the password is only
# needed once. Use a secondary / throwaway account, never your main one.
IG_USERNAME=
IG_PASSWORD=
# How many recent posts to analyze
IG_POST_LIMIT=20
# --- Chrome sessionid (RECOMMENDED for local dev behind a VPN) ---
# In Chrome (logged into instagram.com): F12 -> Application -> Cookies ->
# https://www.instagram.com -> copy the value of the "sessionid" row here.
# This avoids passwords and checkpoints entirely.
IG_SESSIONID=
IG_DS_USER_ID=
# Directory where the cached login session is stored
IG_SESSION_DIR=./.ig_sessions
# If instagram.com is network-blocked (common in Iran), route through a local
# VPN/proxy. Examples:
#   IG_PROXY=http://127.0.0.1:10809      (V2Ray/Xray HTTP inbound)
#   IG_PROXY=socks5h://127.0.0.1:1080    (SOCKS5; resolves DNS via proxy)
IG_PROXY=
